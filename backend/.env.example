DATABASE_URL=postgresql://postgres:postgres@localhost:5432/omniops
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be at least 32 bytes for HS256.
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
UPLOAD_DIR=storage/uploads
ELASTICSEARCH_URL=http://localhost:9200
ES_CHUNK_INDEX=document_chunks
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=document_chunks
EMBEDDING_MODEL_NAME=BAAI/bge-m3
# LiteLLM model string: provider/model. Examples:
#   anthropic/claude-opus-4-8   (needs Anthropic credits)
#   groq/llama-3.3-70b-versatile (free tier)
LLM_MODEL=anthropic/claude-opus-4-8
LLM_API_KEY=
REDIS_URL=redis://localhost:6379/0
# INGEST_SYNC=true processes uploads inline (no Celery worker needed)
INGEST_SYNC=false
# Langfuse LLM tracing (optional) — free keys at cloud.langfuse.com. Leave blank to disable.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
